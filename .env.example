# Twilio (required for sponsor prizes)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Care API (upstream third-party health-data platform at ivr.sohyper.com).
# SECURITY: this integration is OFF by default and fail-closed. It stays
# fixtures-only (no network, nothing leaves our system) unless you explicitly
# set CARE_API_MODE=live below. Only the upstream's own bearer token + a
# User-Agent are ever sent — never a Clara/Sigma/Vapi credential or caller id.
# All upstream calls are timeout-bounded so a hung server can't stall a call.
CARE_API_BASE_URL=
CARE_API_MODE=mock           # mock (default, fixtures-only) | live (calls ivr.sohyper.com)
CARE_API_MOCK=1              # legacy hard kill-switch: =1 forces mock even if MODE=live
CARE_API_TIMEOUT_MS=4000     # per-request egress timeout
# Live auth (only used when CARE_API_MODE=live): the dialogue API needs a
# short-lived JWT. careAuth.ts keeps a rotating pair alive — bootstrap it with
# ONE of the following. Auth endpoints are derived from CARE_API_BASE_URL's
# origin (override with CARE_AUTH_BASE_URL if needed).
CARE_REFRESH_TOKEN=          # a refresh JWT handed off by the operator, or
CARE_BYPASS_URL=             # a fresh .../auth/verify?token=... link (single use, 10 min)
CARE_ACCESS_TOKEN=           # optional: seed access token to skip the first refresh
CARE_API_TOKEN=              # optional legacy/static bearer fallback

# Model gateway
MODEL_PROVIDER=anthropic   # anthropic | openai
MODEL_NAME=                # optional override (defaults: claude-fable-5 / gpt-4o)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=           # optional OpenAI-compatible base (e.g. a router), default api.openai.com/v1

# Vapi (voice pipeline; assistant's custom LLM URL -> PUBLIC_URL)
VAPI_API_KEY=
TELEHEALTH_TRANSFER_NUMBER=   # E.164 number Vapi warm-transfers urgent (non-911) callers to

# App
PORT=3000
PUBLIC_URL=   # public tunnel URL for Vapi -> this server
VAPI_PHONE_NUMBER_ID=   # Vapi phone-number id to bind Clara to
CLARA_ASSISTANT_ID=      # set after first vapi-setup run to make it idempotent
CLARA_PHONE_NUMBER=   # public demo number shown on the root status page
